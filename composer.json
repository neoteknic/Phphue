{
    "name": "neoteknic/phphue",
    "description": "Phphue - Philips Hue PHP client for the Hue API V2 (CLIP v2)",
    "type": "library",
    "keywords": [
        "phphue",
        "phue",
        "philips",
        "hue",
        "clip",
        "api-v2",
        "client"
    ],
    "homepage": "https://github.com/neoteknic/Phphue",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Neoteknic",
            "email": "neoteknic@gmail.com",
            "role": "maintainer"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-json": "*"
    },
    "require-dev": {
        "mockery/mockery": "^1.6.11",
        "phpunit/phpunit": "^10.5.11 || ^11.1.1",
        "phpstan/phpstan": "^2.1.40",
        "friendsofphp/php-cs-fixer": "^v3.94.2",
        "ext-curl": "*"
    },
    "suggest": {
        "ext-curl": "Allows usage of cURL transport adapter (default)"
    },
    "autoload": {
        "psr-4": {
            "Phphue\\": "src/Phphue/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phphue\\Test\\": "tests/Phphue/Test/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse src --no-progress --level=6",
        "phpunit": "phpunit"
    }
}
